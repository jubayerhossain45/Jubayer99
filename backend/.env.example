# ─────────────────────────────────────────────────────────
# Portfolio Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git!
# ─────────────────────────────────────────────────────────

# Server Configuration
PORT=5000

# Frontend origin for CORS (use * for development, your domain in production)
FRONTEND_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────────────
# MongoDB Atlas Connection String
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# ─────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://jubayer_abir:YOUR_PASSWORD_HERE@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# ─────────────────────────────────────────────────────────
# Gmail SMTP Configuration
# IMPORTANT: Use an App Password, NOT your regular Gmail password!
# Steps:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Search "App Passwords" in your Google Account
#   4. Select app: Mail, Device: Other → type "Portfolio"
#   5. Copy the 16-character password (spaces don't matter)
# ─────────────────────────────────────────────────────────
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# Email address where you want to receive contact notifications
OWNER_EMAIL=jubayer123abir@gmail.com
